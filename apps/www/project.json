{
  "name": "www",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "apps/www",
  "sourceRoot": "apps/www/.storybook",
  "tags": [],
  "targets": {
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "port": 4402,
        "configDir": "apps/www/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "dependsOn": [
        "@ks-digital/designsystem-angular:build-storybook",
        "@ks-digital/designsystem-web:build-storybook"
      ],
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/www",
        "configDir": "apps/www/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "www:build-storybook",
        "staticFilePath": "dist/storybook/www",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "www:build-storybook:ci"
        }
      }
    },
    "storybook-all": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run @ks-digital/designsystem-angular:storybook",
          "nx run @ks-digital/designsystem-web:storybook",
          "sleep 5 && nx run www:storybook"
        ],
        "parallel": true
      }
    }
  }
}
