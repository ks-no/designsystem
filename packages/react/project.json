{
  "name": "@ks-digital/designsystem-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/react/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": [
        {
          "target": "build",
          "projects": ["@ks-digital/designsystem-themes"]
        }
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "port": 4403,
        "configDir": "packages/react/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "dependsOn": ["@ks-digital/designsystem-themes:build"],
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/@ks-digital/designsystem-react",
        "configDir": "packages/react/.storybook"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "@ks-digital/designsystem-react:build-storybook",
        "staticFilePath": "dist/storybook/@ks-digital/designsystem-react",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "@ks-digital/designsystem-react:build-storybook:ci"
        }
      }
    }
  }
}
