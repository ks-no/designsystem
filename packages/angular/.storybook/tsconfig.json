{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["node"]
  },
  "exclude": ["../**/*.spec.ts"],
  "include": [
    "../**/*.stories.ts",
    "../**/*.stories.js",
    "../**/*.stories.jsx",
    "../**/*.stories.tsx",
    "../**/*.mdx",
    "*.js",
    "*.ts",
    "./components/**/*.tsx"
  ]
}
